{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "type": "kitty-direct",
    "source": "/home/yugaaank/.config/fastfetch/images/head.png",
    "width": 28,
    "height": 12,
    "padding": {
      "top": 2,
      "left": 2
    }
  },
  "display": {
    "separator": " {#90}│ {#keys}",
    "color": {
      "keys": "cyan"
    }
  },
  "modules": [
    {
      "type": "title",
      "key": "  {#36}",
      "format": "{user-name}@{host-name}"
    },
    {
      "type": "custom",
      "format": "{#90}  ──────────────────────────────"
    },
    {
      "type": "os",
      "key": "  {#36}󰣇 os"
    },
    {
      "type": "kernel",
      "key": "  {#36}󰒋 ker"
    },
    {
      "type": "uptime",
      "key": "  {#36}󰅐 upt"
    },
    {
      "type": "wm",
      "key": "  {#36}󱂬 wm "
    },
    {
      "type": "shell",
      "key": "  {#36} sh "
    },
    {
      "type": "memory",
      "key": "  {#36} mem"
    },
    {
      "type": "disk",
      "key": "  {#36}󰋊 dsk"
    },
    {
      "type": "custom",
      "format": "{#90}  ──────────────────────────────"
    },
    {
      "type": "colors",
      "key": "  {#36} cls",
      "symbol": "circle"
    }
  ]
}
